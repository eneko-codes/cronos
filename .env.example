# =============================================================================
# APPLICATION INFORMATION
# =============================================================================
APP_NAME="Cronos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Madrid
APP_URL=http://cronos.test

# =============================================================================
# LOCALIZATION
# =============================================================================
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# =============================================================================
# MAINTENANCE MODE
# =============================================================================
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# =============================================================================
# SECURITY
# =============================================================================
BCRYPT_ROUNDS=12

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cronos
DB_USERNAME=
DB_PASSWORD=
SCOUT_DRIVER=database

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_MODEL=App\Models\User
AUTH_REMEMBER_LIFETIME=43200

# =============================================================================
# RATE LIMIT CONFIGURATION
# =============================================================================
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=4
LOGIN_RATE_LIMIT_DECAY_MINUTES=5
ADMIN_RATE_LIMIT_MAX_ATTEMPTS=60
ADMIN_RATE_LIMIT_DECAY_MINUTES=1
WEB_RATE_LIMIT_MAX_ATTEMPTS=30
WEB_RATE_LIMIT_DECAY_MINUTES=1

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_STORE=database
CACHE_PREFIX=cronos_cache_
DB_CACHE_CONNECTION=pgsql
DB_CACHE_LOCK_CONNECTION=pgsql
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_TABLE=cache_locks

# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=pgsql
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=240
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_CONNECTION=pgsql
SESSION_TABLE=sessions
SESSION_STORE=
SESSION_COOKIE=cronos_session
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# =============================================================================
# MAIL CONFIGURATION
# =============================================================================
MAIL_MAILER=log
MAIL_URL=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="name@mail.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SENDMAIL_PATH=
MAIL_LOG_CHANNEL=single

# =============================================================================
# FILESYSTEM CONFIGURATION
# =============================================================================
FILESYSTEM_DISK=local

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# Odoo Configuration
ODOO_BASE_URL=
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_PASSWORD=

# ProofHub Configuration
PROOFHUB_COMPANY_URL=
PROOFHUB_API_KEY=

# DeskTime Configuration
DESKTIME_BASE_URL=https://desktime.com/api/v2/json
DESKTIME_API_KEY=

# SystemPin Configuration
SYSTEMPIN_BASE_URL=
SYSTEMPIN_API_KEY=
SYSTEMPIN_TIMEZONE=Europe/Madrid

# =============================================================================
# VITE CONFIGURATION
# =============================================================================
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# TELESCOPE CONFIGURATION
# =============================================================================
TELESCOPE_ENABLED=true
TELESCOPE_DOMAIN=
TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database
TELESCOPE_QUEUE_CONNECTION=null
TELESCOPE_QUEUE=null
TELESCOPE_BATCH_WATCHER=true
TELESCOPE_CACHE_WATCHER=true
TELESCOPE_CLIENT_REQUEST_WATCHER=true
TELESCOPE_COMMAND_WATCHER=true
TELESCOPE_DUMP_WATCHER=true
TELESCOPE_DUMP_WATCHER_ALWAYS=true
TELESCOPE_EVENT_WATCHER=true
TELESCOPE_EXCEPTION_WATCHER=true
TELESCOPE_GATE_WATCHER=true
TELESCOPE_JOB_WATCHER=true
TELESCOPE_LOG_WATCHER=true
TELESCOPE_MAIL_WATCHER=true
TELESCOPE_MODEL_WATCHER=true
TELESCOPE_NOTIFICATION_WATCHER=true
TELESCOPE_QUERY_WATCHER=true
TELESCOPE_REDIS_WATCHER=true
TELESCOPE_REQUEST_WATCHER=true
TELESCOPE_RESPONSE_SIZE_LIMIT=0
TELESCOPE_SCHEDULE_WATCHER=true
TELESCOPE_VIEW_WATCHER=true

# =============================================================================
# PULSE CONFIGURATION
# =============================================================================
PULSE_ENABLED=true
PULSE_DOMAIN=
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_DB_CONNECTION=pgsql
PULSE_INGEST_DRIVER=storage
PULSE_INGEST_BUFFER=5000
PULSE_SLOW_JOBS_ENABLED=true
PULSE_SLOW_JOBS_SAMPLE_RATE=1
PULSE_SLOW_JOBS_THRESHOLD=1000
PULSE_EXCEPTIONS_ENABLED=true
PULSE_EXCEPTIONS_SAMPLE_RATE=1
PULSE_EXCEPTIONS_LOCATION=true
PULSE_CACHE_DRIVER=database
PULSE_REDIS_CONNECTION=default
PULSE_QUEUES_ENABLED=true
PULSE_QUEUES_SAMPLE_RATE=1
PULSE_SLOW_OUTGOING_REQUESTS_ENABLED=true
PULSE_SLOW_OUTGOING_REQUESTS_SAMPLE_RATE=1
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=1000
PULSE_SLOW_QUERIES_ENABLED=true
PULSE_SLOW_QUERIES_SAMPLE_RATE=1
PULSE_SLOW_QUERIES_THRESHOLD=1000
PULSE_SLOW_QUERIES_MAX_QUERY_LENGTH=
PULSE_SLOW_REQUESTS_ENABLED=true
PULSE_SLOW_REQUESTS_SAMPLE_RATE=1
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_USER_JOBS_ENABLED=true
PULSE_USER_JOBS_SAMPLE_RATE=1
PULSE_USER_REQUESTS_ENABLED=true
PULSE_USER_REQUESTS_SAMPLE_RATE=1