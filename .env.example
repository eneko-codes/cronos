# Application Information
APP_NAME="Cronos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://cronos.test

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database # Uncomment only if using 'cache' driver

# Server Configuration
PHP_CLI_SERVER_WORKERS=4

# Security
BCRYPT_ROUNDS=12

# Logging Configuration
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# Choose one of the following database configurations:

# PostgreSQL Configuration (Recommended for Production)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cronos_db
DB_USERNAME=cronos_user
DB_PASSWORD=your_secure_password

# SQLite Configuration (Development Only)
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/your/storage/database.sqlite

# Authentication Configuration
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_MODEL=App\Models\User
AUTH_PASSWORD_RESET_TOKEN_TABLE=
AUTH_PASSWORD_TIMEOUT=10800

# Cache Configuration
CACHE_STORE=database
CACHE_PREFIX=cronos_cache_
# Database connection for cache (should match your main DB_CONNECTION)
DB_CACHE_CONNECTION=pgsql
DB_CACHE_LOCK_CONNECTION=pgsql
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_TABLE=cache_locks

# Queue Configuration
QUEUE_CONNECTION=database
QUEUE_DEFAULT=default
# Database connection for queue (should match your main DB_CONNECTION)
DB_QUEUE_CONNECTION=pgsql
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=240
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false # Set to true on production
# Database connection for sessions (should match your main DB_CONNECTION)
SESSION_CONNECTION=pgsql
SESSION_TABLE=sessions
SESSION_STORE=
SESSION_COOKIE=cronos_session
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false # Set to true in production to ensure cookies are only sent over HTTPS
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# Mail Configuration
MAIL_MAILER=log
MAIL_URL=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="cronos@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SENDMAIL_PATH=
MAIL_LOG_CHANNEL=single

# Filesystem Configuration
FILESYSTEM_DISK=local

# Third-Party Services
ODOO_BASE_URL=https://your-odoo-instance.com
ODOO_DATABASE=your_database
ODOO_USERNAME=your_username
ODOO_PASSWORD="your_password"
PROOFHUB_COMPANY_URL=your_company
PROOFHUB_API_KEY=your_api_key
DESKTIME_BASE_URL=https://desktime.com/api/v2/json
DESKTIME_API_KEY=your_api_key
SYSTEMPIN_BASE_URL=https://your-systempin-instance.com/rest/presenciapin
SYSTEMPIN_API_KEY=your_systempin_api_key

# Vite Configuration
VITE_APP_NAME="${APP_NAME}"

# Telescope Configuration
TELESCOPE_ENABLED=true
TELESCOPE_DOMAIN=
TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database
TELESCOPE_QUEUE_CONNECTION=null
TELESCOPE_QUEUE=null
TELESCOPE_BATCH_WATCHER=true
TELESCOPE_CACHE_WATCHER=true
TELESCOPE_CLIENT_REQUEST_WATCHER=true
TELESCOPE_COMMAND_WATCHER=true
TELESCOPE_DUMP_WATCHER=true
TELESCOPE_DUMP_WATCHER_ALWAYS=true
TELESCOPE_EVENT_WATCHER=true
TELESCOPE_EXCEPTION_WATCHER=true
TELESCOPE_GATE_WATCHER=true
TELESCOPE_JOB_WATCHER=true
TELESCOPE_LOG_WATCHER=true
TELESCOPE_LOG_LEVEL=info
TELESCOPE_MAIL_WATCHER=true
TELESCOPE_MODEL_WATCHER=true
TELESCOPE_NOTIFICATION_WATCHER=true
TELESCOPE_QUERY_WATCHER=true
TELESCOPE_REDIS_WATCHER=true
TELESCOPE_REQUEST_WATCHER=true
TELESCOPE_RESPONSE_SIZE_LIMIT=0
TELESCOPE_SCHEDULE_WATCHER=true
TELESCOPE_VIEW_WATCHER=true

# Pulse Configuration
PULSE_ENABLED=true
PULSE_DOMAIN=
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
# Database connection for Pulse (should match your main DB_CONNECTION)
PULSE_DB_CONNECTION=pgsql
PULSE_INGEST_DRIVER=storage
PULSE_INGEST_BUFFER=5000
PULSE_SLOW_JOBS_ENABLED=true
PULSE_SLOW_JOBS_SAMPLE_RATE=1
PULSE_SLOW_JOBS_THRESHOLD=1000
PULSE_EXCEPTIONS_ENABLED=true
PULSE_EXCEPTIONS_SAMPLE_RATE=1
PULSE_EXCEPTIONS_LOCATION=true
PULSE_CACHE_DRIVER=database
PULSE_REDIS_CONNECTION=default
PULSE_QUEUES_ENABLED=true
PULSE_QUEUES_SAMPLE_RATE=1
PULSE_SLOW_OUTGOING_REQUESTS_ENABLED=true
PULSE_SLOW_OUTGOING_REQUESTS_SAMPLE_RATE=1
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=1000
PULSE_SLOW_QUERIES_ENABLED=true
PULSE_SLOW_QUERIES_SAMPLE_RATE=1
PULSE_SLOW_QUERIES_THRESHOLD=1000
PULSE_SLOW_QUERIES_MAX_QUERY_LENGTH=
PULSE_SLOW_REQUESTS_ENABLED=true
PULSE_SLOW_REQUESTS_SAMPLE_RATE=1
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_USER_JOBS_ENABLED=true
PULSE_USER_JOBS_SAMPLE_RATE=1
PULSE_USER_REQUESTS_ENABLED=true
PULSE_USER_REQUESTS_SAMPLE_RATE=1